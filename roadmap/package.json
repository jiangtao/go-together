{
  "name": "roadmap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "generate:public": "node --import tsx scripts/generate-public.ts",
    "check:determinism": "node --import tsx scripts/check-public-determinism.ts",
    "audit:generated": "node --import tsx scripts/audit-public.ts generated",
    "audit:dist": "node --import tsx scripts/audit-public.ts dist",
    "package:prebuilt": "node --import tsx scripts/package-prebuilt.ts",
    "audit:prebuilt": "node --import tsx scripts/audit-prebuilt.ts",
    "evidence:manifest": "node --import tsx scripts/create-e2e-evidence-manifest.ts",
    "dev:vite": "vite",
    "dev": "npm run generate:public && vite",
    "build:app": "vite build",
    "build": "npm run generate:public && npm run check:determinism && npm run audit:generated && npm run typecheck && npm run build:app && npm run audit:dist && npm run package:prebuilt && npm run audit:prebuilt",
    "build:hosting": "npm run generate:public && npm run check:determinism && npm run audit:generated && npm run build:app && npm run audit:dist && npm run package:prebuilt && npm run audit:prebuilt",
    "build:release": "npm run generate:public && npm run check:determinism && npm run audit:generated && npm run lint && npm run typecheck && npm run test && npm run build:app && npm run audit:dist && npm run package:prebuilt && npm run audit:prebuilt",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run generate:public && playwright test && npm run evidence:manifest",
    "serve:e2e": "npm run generate:public && vite --host 127.0.0.1 --port 4173",
    "smoke:deployment": "node --import tsx scripts/smoke-deployment.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "ipaddr.js": "2.4.0",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.10"
  }
}

{
  "name": "roadmap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync": "tsx scripts/sync-course.ts",
    "watch": "tsx scripts/watch-course.ts",
    "dev:vite": "vite",
    "dev": "npm run sync && concurrently --kill-others-on-fail --names sync,vite --prefix-colors cyan,magenta \"npm run watch\" \"npm run dev:vite\"",
    "prebuild": "npm run sync",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "serve:e2e": "npm run sync && vite --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@xyflow/react": "^12.11.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.10"
  }
}
